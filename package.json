{
  "name": "@er/eslint",
  "version": "1.0.0",
  "description": "ER monorepo with ESLint packages",
  "scripts": {
    "build:linterall": "npm run -w @er/linterall build",
    "build:plugin-tsdoc": "npm run -w @er/eslint-plugin-tsdoc build",
    "postinstall": "npm run build:linterall",
    "lint": "eslint -c eslint.config.mjs packages/plugin-tsdoc/src/rules/syntax/syntax.ts"
  },
  "author": "Eduardo Russo",
  "license": "MIT",
  "devDependencies": {
    "@eslint/config-helpers": "^0.5.2",
    "@eslint/json": "^1.0.1",
    "@eslint/markdown": "^7.5.1",
    "@rollup/plugin-typescript": "^12.3.0",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-jsonc": "^3.1.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-yml": "^3.3.0",
    "globals": "latest",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-missing-exports": "^4.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "@types/node": "$@types/node",
    "eslint": "$eslint",
    "globals": "$globals",
    "minimatch": "latest",
    "typescript": "$typescript",
    "typedoc": "$typedoc"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "ansi-colors": "^4.1.3",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "inquirer-file-selector": "^1.0.1"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
